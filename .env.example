# OKO API production environment
# Copy to .env and set before: docker compose up -d

PORT=3001

# Database — choose one:
#
# Production (Render / Railway): managed PostgreSQL
# DATABASE_URL=postgresql://user:pass@host:5432/oko
# DATABASE_SSL=false   # only if provider does not require SSL
#
# Local dev / Docker without Postgres: SQLite file
OKO_DB_PATH=./data/oko.db

# Auth — choose one or combine:
#
# Local dev (recommended): disable API auth entirely
OKO_AUTH_DISABLED=1
#
# 1) Legacy Bearer tokens (methodologist / service accounts)
# If OKO_ADMIN_TOKEN is set, all /api/* routes except public auth require a token.
# OKO_ADMIN_TOKEN=change-me-admin-secret
# OKO_USER_TOKEN=change-me-user-secret
#
# 2) User accounts (org cabinets) — login/password in portal
# On first DB init, if no users exist, creates admin from:
OKO_BOOTSTRAP_ADMIN_USER=admin
OKO_BOOTSTRAP_ADMIN_PASSWORD=change-me-bootstrap-password
#
# LDAP integration — planned for a later phase.

# Portal (Vite build) — URL of hosted API for static deploy without proxy
# VITE_API_URL=https://oko-api.example.com
