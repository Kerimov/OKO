# OKO production — copy to .env.prod before: ./scripts/prod-up.sh
# ТЗ: on-prem Docker, PostgreSQL, без Vercel/Render.

# HTTP port on host (nginx portal + /api proxy)
OKO_HTTP_PORT=8080

# PostgreSQL (container postgres)
POSTGRES_USER=oko
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=oko

# Bootstrap admin (first start, empty users table)
OKO_BOOTSTRAP_ADMIN_USER=admin
OKO_BOOTSTRAP_ADMIN_PASSWORD=change-me-bootstrap-password

# Auth: 0 = login/password required; 1 = only for isolated dev
OKO_AUTH_DISABLED=0

# Optional legacy Bearer tokens (service accounts)
# OKO_ADMIN_TOKEN=
# OKO_USER_TOKEN=

# Reload kontr agents from portal/public/data/kontr.json on API start
# OKO_REIMPORT_KONTR_ON_START=1

# Postgres Pro / managed DB with SSL
# DATABASE_SSL=true
