{
  "name": "oko-portal",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && npm run build:offline-template && vite build",
    "build:offline-template": "VITE_OFFLINE_KIT=true tsc --noEmit && VITE_OFFLINE_KIT=true vite build && node ../scripts/zip-offline-template.mjs",
    "build:offline-kit": "npm run build:offline-template",
    "preview": "vite preview"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "pdfmake": "^0.3.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/pdfmake": "^0.3.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
