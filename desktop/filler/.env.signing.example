# Скопируйте в .env.signing (файл в git не попадает).
#
# 1) Самоподписанный сертификат (тест / внутренняя сеть):
#    powershell -ExecutionPolicy Bypass -File scripts/create-signing-cert.ps1
#
# 2) Сборка:
#    npm run dist:signed
#
# Для пользователей вне домена без предупреждений SmartScreen нужен
# коммерческий Code Signing (OV/EV) от DigiCert, Sectigo и т.п.

CSC_LINK=build/oko-signing.pfx
CSC_KEY_PASSWORD=change-me-after-create-cert

# Альтернатива: сертификат уже в хранилище Windows
# WIN_CSC_LINK=sha256:THUMBPRINT
