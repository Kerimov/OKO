{
  "name": "oko-filler",
  "private": true,
  "version": "0.1.0",
  "description": "ОКО Заполнение — десктоп для дочерних организаций",
  "author": "OKO",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "predist": "node scripts/kill-and-clean-release.mjs",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable -c.win.signExecutable=false",
    "dist:signed": "node scripts/dist-signed.mjs",
    "dist:setup": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis -c.win.signExecutable=false",
    "dist:setup:signed": "node scripts/dist-signed.mjs --nsis",
    "dist:dir": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --dir",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "cross-env": "^7.0.3",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "ru.oko.filler",
    "productName": "ОКО Заполнение",
    "copyright": "Copyright © OKO",
    "directories": {
      "output": "installer",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/sql.js/**/*"
    ],
    "extraFiles": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "dist-electron/sql-wasm.wasm"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../../reference/icon-OKO.ico",
      "signAndEditExecutable": true,
      "verifyUpdateCodeSignature": false
    },
    "portable": {
      "artifactName": "OKO-Zapolnenie-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OKO Zapolnenie"
    }
  }
}
