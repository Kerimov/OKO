{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OKO Zapolnenie",
  "version": "0.1.0",
  "identifier": "ru.oko.filler",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ОКО Заполнение",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "msi", "appimage", "deb"],
    "category": "Business",
    "shortDescription": "ОКО Заполнение — офлайн-заполнение форм комплекта",
    "longDescription": "Десктоп-клиент для совместного заполнения отчётного комплекта ОКО на общей папке (SMB) с SQLite WAL.",
    "copyright": "OKO",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/rachel.c@example.org",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Russian", "English"]
      }
    }
  },
  "plugins": {}
}
